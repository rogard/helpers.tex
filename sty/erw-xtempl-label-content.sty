\ProvidesExplPackage
{erw-xtempl-label-content}
{2026/04/11}{1.1}
{An xtemplate for a label-content pair}

\usepackage{xtemplate}

\DeclareObjectType
{erw-binary}{2}

\DeclareTemplateInterface
{erw-binary}
{erw-label-content}
{2}
{
  % <See: pkg l3str-format>
  label : tokenlist = {.<2}, % \seq_format:Nn\l_tmpa_seq{<label>}
  content : function{1} = #1,
  % </>
  combine : function{2} = #1~#2 % {<label_str>}{<content_str>}
}

\DeclareTemplateCode
{erw-binary}
{erw-label-content}
{2}
{
  label = \l__erw_label_tl,
  content = \__erw_content:n,
  combine = \__erw_combine:nn
}
{
  \group_begin:
  \seq_set_from_clist:Nn \l_tmpa_seq { #1 }        % fix 1: seq not clist
  \str_set:Ne \l_tmpa_str
  { \exp_args:NNV \seq_format:Nn \l_tmpa_seq \l__erw_label_tl }
  %\str_show:N \l_tmpa_str
  \exp_args:NNe
  \tl_set:Nn \l_tmpb_tl { \__erw_content:n{#2} }
  %\str_show:N \l_tmpb_str
  \exp_args:NVV \__erw_combine:nn \l_tmpa_str \l_tmpb_tl
  \group_end:
}
