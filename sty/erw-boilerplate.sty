\ProvidesExplPackage{erw-boilerplate}{2026/04/22}{1.2}
{ Standalone expl3-like commands }

% -----------------------------------------------------------------
% integer

\cs_new:Npn
\erw_int_last:nn
#1 % <first>
#2 % <count>
{ \int_eval:n{ #1 + #2 - 1} }

\cs_new:Npn
\erw_int_from_tl:n
#1 % <tl>
{%
  \int_eval:n{ #1 + 0 }
  % MWE:
  % \tl_set:Nn\l_tmpa_tl{ 04 }
  % \erw_int_from_tl:N\l_tmpa_tl
}

\prg_new_conditional:Npnn \erw_int_in_range:nnn #1#2#3 { TF }
{
  \bool_lazy_and:nnTF
  {
    \int_compare_p:n { #1 >= #2 }
  }
  {
    \int_compare_p:n { #1 <= #3 }
  }
  { \prg_return_true: }
  { \prg_return_false: }
}

% -----------------------------------------------------------------
% box

\cs_new_protected:Nn
\erw_content_width_set:N
{
  \dim_set:NV \hsize #1
  \dim_set_eq:NN \linewidth \hsize
  \dim_zero:N \parindent
  % Usage:
  % \vbox_set_top:Nn \l_tmpa_box
  % { % analogous to `\parbox`
  %   \erw_content_width_set:N\l__erw_width_dim
  %   \tl_use:N\l__erw_marginnote_switch_tl
  %   \strut \tl_trim_spaces:n{ #1 }
  % }
}

\cs_new_protected:Nn \erw_strut_text:
{%
  \tex_unhcopy:D \strutbox
}

\cs_new_protected:Nn \erw_strut_math:
{%
  \tex_copy:D \strutbox
}

\cs_new_protected:Nn \erw_strut:
{%
  \mode_if_math:TF
  { \erw_strut_math: }
  { \erw_strut_text: }
}

\cs_new_protected:Nn \erw_noindent:
{%
  \dim_zero:N \parindent
  \mode_leave_vertical:
  % Ensures that TEX is not in vertical (inter-paragraph) mode. In horizontal or math mode
  % this command has no effect, in vertical mode it switches to horizontal mode, and inserts
  % a box of width \parindent, followed by the \everypar token list.
  % https://mirror.math.princeton.edu/pub/CTAN/macros/latex/required/l3kernel/interface3.pdf#section.4.7
}

\cs_new_protected:Nn \erw_box_smash:N
{
  \box_set_ht:Nn #1 { 0pt }
  \box_set_dp:Nn #1 { 0pt }
}

\mode_if_horizontal:T
{
  \skip_set_eq:NN \l__scontents_save_skip \tex_lastskip:D
  \int_set_eq:NN \l__scontents_save_sf_int \tex_spacefactor:D
}

% -----------------------------------------------------------------
% calendar

\regex_const:Nn
\c_erw_cal_iso_regex
{ ^[[:digit:]]{4}-[[:digit:]]{2}-[[:digit:]]{2}$ }

\cs_new_protected:Npn
\erw_cal_iso_as_keyval:NN
#1 % <yyyy-mm-dd>
#2 % <prop>
{
  \group_begin:

  \regex_match:NVTF
  \c_erw_cal_iso_regex
  #1
  {
    \seq_set_split:NnV \l_tmpa_seq { - } { #1 }

    \seq_pop_left:NN \l_tmpa_seq \l_tmpa_tl
    \prop_gput:NnV #2 { year } \l_tmpa_tl

    \seq_pop_left:NN \l_tmpa_seq \l_tmpa_tl
    \prop_gput:NnV #2 { month } \l_tmpa_tl

    \seq_pop_left:NN \l_tmpa_seq \l_tmpa_tl
    \prop_gput:NnV #2 { day } \l_tmpa_tl
  }
  {
    \msg_warning:nnn { __erw_cal } { invalid-date } { #1 }
  }

  \group_end:
}

\cs_new:Npn\__erw_cal_quarter:n
#1 % <month_int>
{%
  \int_eval:n
  { ( #1 - 1 ) / 3 + 1 }
}

\cs_new:Npn\erw_cal_quarter:n
#1 % <tl>
{%
  \exp_args:Ne
  \__erw_cal_quarter:n
  {%
    \erw_int_from_tl:n{ #1 }
  }
}

% -----------------------------------------------------------------
% function

\cs_new:Npn
\erw_parameter_braced:n
#1 % <index>
{ \exp_not:n{ {## #1} } }

\cs_new:Npn
\erw_parameter_braced:nn
#1 % <first>
#2 % <last>
{ \int_step_function:nnN {#1}{#2}\erw_parameter_braced:n }
\cs_generate_variant:Nn\erw_parameter_braced:nn{ne}

\cs_new_protected:Npn
\erw_inline:nn
#1 % <arg spec>
#2 % <code>
{
  \cs_gset:cn{__erw_lambda:#1}{#2}
  \use:c{__erw_lambda:#1}
}
% Example:
% \erw_inline:nn{n}{Hello~#1!}{world}

\cs_new_protected:Npn
\erw_scope_infix_type:nNN
#1 % <input>
#2 % <output>
#3 % <regex>
{
  \seq_set_regex_extract_once:NNn
  #2
  #3
  { #1 }
}

\cs_new_protected:Npn
\erw_scope_infix_type:NNN
#1 % <input>
#2 % <output>
#3 % <regex>
{
  \exp_args:Ne
  \erw_scope_infix_type:nNN
  { \cs_to_str:N #1 }
  #2#3
  % Example:
  % \erw_scope_infix_type:NN
  % \l__foo_str
  % \l_tmpa_seq
  % \exp_args:Ne\tl_show:n{
  % Scope: \seq_item:Nn\l_tmpa_seq{ 2 } % l
  % Infix: \seq_item:Nn\l_tmpa_seq{ 3 } % foo
  % Type: \seq_item:Nn\l_tmpa_seq{ 4 } % str
  % }
}

% -----------------------------------------------------------------
% clist

\cs_new_protected:Npn
\erw_clist_sort_in_place:N
#1 % <clist>
{
  \clist_sort:Nn#1
  {
    \str_compare:nNnTF { ##1 } < { ##2 }
    { \sort_return_same: }
    { \sort_return_swapped: }
  }
}

\prg_new_protected_conditional:Npnn
\erw_clist_if_subset:NN #1#2 { TF }
{
  \clist_map_inline:Nn #1
  {
    \clist_if_in:NnF #2 { ##1 }
    { \prg_return_false: }
  }
  \prg_return_true:
}
