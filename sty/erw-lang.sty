\ProvidesExplPackage
{erw-lang}{2026/05/05}{1.1}
{ Package-agnostic interface for detecting loaded languages }

% Usage:
% ```
% \erw_lang_loaded:nTF{<language>{<code1>}{<code2}
% \IfLangLoaded{<language>{<code1>}{<code2>}
% ```

\socket_new:nn {erw-lang-loaded} {1}  % language name

\makeatletter

\socket_new_plug:nnn {erw-lang-loaded} {babel} 
{ \cs_if_exist:cTF {bbl@loaded@#1} }

\socket_new_plug:nnn {erw-lang-loaded} {polyglossia}
{ \clist_if_in:NnTF \xpg@loaded {#1} }

\makeatother

\seq_gset_from_clist:Nn
\g__erw_lang_plugs_seq
{
  babel,
  polyglossia
} % Extend as necessary

\seq_map_inline:Nn \g__erw_lang_plugs_seq {
  \IfPackageLoadedTF{#1} {
    \socket_assign_plug:nn {erw-lang-loaded} {#1}
    \seq_map_break:  % Stop after first match
  }{}
}

\prg_new_conditional:Npnn
\erw_lang_loaded:n #1 { TF }
{
  \socket_use:nn {erw-lang-loaded} {#1}
  { \prg_return_true: }
  { \prg_return_false: }
}

\NewDocumentCommand{\IfLangLoaded}{m m m}
{
  \erw_lang_loaded:nTF {#1} {#2} {#3}
}

\socket_new:nn{ erw-lang-active }{ 0 }

\socket_new_plug:nnn {erw-lang-active} {babel} 
{ \languagename }

\socket_new_plug:nnn {erw-lang-active} {polyglossia}
{ \languagename }

\seq_map_inline:Nn \g__erw_lang_plugs_seq {
  \IfPackageLoadedTF{ #1 } {
    \socket_assign_plug:nn {erw-lang-active} {#1}
    \seq_map_break:  % Stop after first match
  }{}
}

\cs_new:Nn
\erw_lang_active:
{%
  \socket_use:nn{erw-lang-active}{}
}
